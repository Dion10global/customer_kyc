# Copy this file to .env for local development. Never commit .env itself.
# In production, set these as Vercel Project Environment Variables. They point
# at an external managed MySQL (Railway / Aiven) because Vercel has no database.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=companydb
DB_USER=root
DB_PASSWORD=change_me

# TLS CA for managed MySQL (Aiven requires SSL). Leave empty for local/CI.
# Set in production to EITHER the CA's PEM contents OR a path. The repo bundles
# the cert, so the simplest production value is: DB_SSL_CA=certs/aiven-ca.pem
DB_SSL_CA=
